/**
 * UI Renderer: Generates formatted tables for Research Terminal
 */
function _renderSummaryTables(targetTab, providers, nations, operators) {
  let rowCursor = 1;
  
  const generateTable = (dataset, title, headerHex) => {
    targetTab.getRange(rowCursor, 1).setValue(title).setFontWeight("bold").setFontSize(12);
    
    // Rows are generated via internal formatting function [Logic Hidden]
    const formattedRows = _buildOutputMatrix(dataset, title);
    
    targetTab.getRange(rowCursor + 1, 1, formattedRows.length, 5).setValues(formattedRows);
    targetTab.getRange(rowCursor + 1, 1, 1, 5).setBackground(headerHex).setFontColor("white").setFontWeight("bold");
    
    rowCursor += formattedRows.length + 3;
  };

  generateTable(providers, "Launch Provider Performance (YoY)", "#1a73e8");
  generateTable(nations, "National Launch Activity (YoY)", "#1e8e3e");
  generateTable(operators, "Satellite Operator Distribution (YoY)", "#e67c73");

  targetTab.autoResizeColumns(1, 5);
}

