/**
 * Executes the primary ETL process: Fetch, Filter, and Segment
 */
function runSpaceLogUpdate_Master() {
  const SOURCE_URL = "https://planet4589.org/space/gcat/tsv/derived/launchlog.tsv";
  const TARGET_SHEET = "Space_Research_Terminal";
  
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let dataSheet = ss.getSheetByName(TARGET_SHEET) || ss.insertSheet(TARGET_SHEET);
  
  try {
    const response = UrlFetchApp.fetch(SOURCE_URL);
    const rawData = Utilities.parseCsv(response.getContentText(), '\t');
    
    // Filter for current and forward-looking fiscal periods (2025-2026)
    const filteredData = rawData.filter((row, index) => {
      if (index === 0) return true; // Keep Header
      const launchTag = String(row[0]);
      return launchTag.includes("2025") || launchTag.includes("2026");
    });

    dataSheet.clear();
    dataSheet.getRange(1, 1, filteredData.length, filteredData[0].length)
             .setNumberFormat("@")
             .setValues(filteredData);
    
    // Trigger downstream analytics engine
    generateSpaceStats_V2(filteredData);
    
    console.info("Pipeline Sync Successful: %s rows processed", filteredData.length);
  } catch (err) {
    console.error("Pipeline Sync Error: " + err.message);
  }
}

/**
 * Analytical Processor: Aggregates raw logs into YoY Sector Metrics
 * @param {Array} data - Filtered TSV rows
 */
function generateSpaceStats_V2(data) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const summaryTab = ss.getSheetByName("Sector_Summary_Stats") || ss.insertSheet("Sector_Summary_Stats");
  summaryTab.clear();

  // Field Mapping for G-CAT Schema
  const COL_MAP = {
    TAG: 0,
    OWNER: 7,
    AGENCY: 16,
    COUNTRY: 17
  };

  let providers = {}, nations = {}, operators = {};
  data.shift(); // Remove headers for iteration

  data.forEach(row => {
    const launchId = String(row[COL_MAP.TAG]);
    const fiscalYear = launchId.substring(0, 4);
    
    // Logic Abstraction: Data is passed to internal mapping functions 
    // to protect proprietary ownership/state classification logic.
    const metrics = _parseInternalMetrics(row, fiscalYear, COL_MAP);
    
    _mapToStorage(providers, metrics.agency, fiscalYear, metrics.id);
    _mapToStorage(nations, metrics.nation, fiscalYear, metrics.id);
    _mapToStorage(operators, metrics.ownerKey, fiscalYear, metrics.id);
  });

  _renderSummaryTables(summaryTab, providers, nations, operators);
}

