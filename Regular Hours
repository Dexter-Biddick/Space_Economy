function logDollarVolumeHistory(results) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let logSheet = ss.getSheetByName("TOTAL $ VOL HISTORY") || ss.insertSheet("TOTAL $ VOL HISTORY");
  let awardSheet = ss.getSheetByName("Awards of the day") || ss.insertSheet("Awards of the day");

  if (logSheet.getLastRow() === 0) {
    const logHeaders = ["Date", "Time", "Total Sector $ Vol", "Space Daddy", "Crater Maker", "Super Heavy-Lift", "Orbital Yeet", "Deep Space Silence", "Con Artist", "Slingshot Maneuverer"];
    logSheet.appendRow(logHeaders);
    logSheet.getRange("A1:J1").setFontWeight("bold").setBackground("#0d1b2a").setFontColor("white");
  }

  const totalDollarVol = results.reduce((sum, row) => sum + (row[9] || 0), 0);
  
  let last5Data = logSheet.getRange(Math.max(1, logSheet.getLastRow() - 4), 1, 5, 3).getValues();
  let trendTweet = `📈 Sector Trend (5D)\n\n`;
  last5Data.forEach(row => {
    if (row[0] && row[0] instanceof Date) {
      let date = Utilities.formatDate(new Date(row[0]), Session.getScriptTimeZone(), "MMM d");
      let vol = (row[2] / 1000000).toFixed(1);
      trendTweet += `${date}: $${vol}M\n`;
    }
  });
  trendTweet += `TODAY: $${(totalDollarVol / 1000000).toFixed(1)}M\n\n#SpaceStocks #MarketData`;

  const daddy = [...results].sort((a, b) => b[2] - a[2])[0];
  const crater = [...results].sort((a, b) => a[2] - b[2])[0];
  const heavy = [...results].sort((a, b) => b[9] - a[9])[0];
  const yeet = [...results].sort((a, b) => b[7] - a[7])[0];
  const silence = [...results].sort((a, b) => a[7] - b[7])[0];

  const daddyData = { ticker: daddy[0], stat: `+${(daddy[2] * 100).toFixed(1)}%` };
  const craterData = { ticker: crater[0], stat: `${(crater[2] * 100).toFixed(1)}%` };
  const heavyData = { ticker: heavy[0], stat: `$${Math.round(heavy[9] / 1000000)}M` };
  const yeetData = { ticker: yeet[0], stat: `${yeet[7].toFixed(2)}x` };
  const silenceData = { ticker: silence[0], stat: `${silence[7].toFixed(2)}x` };

  let conArtistTicker = "None", slingshotTicker = "None", biggestFade = 0, biggestRecovery = 0;
  results.forEach(row => {
    let ticker = row[0], finalPct = row[2], gap = row[12];
    if (gap > 0 && finalPct < gap && (gap - finalPct) > biggestFade) { biggestFade = gap - finalPct; conArtistTicker = ticker; }
    if (gap < 0 && finalPct > gap && (finalPct - gap) > biggestRecovery) { biggestRecovery = finalPct - gap; slingshotTicker = ticker; }
  });

  const conArtistStat = conArtistTicker !== "None" ? `-${(biggestFade * 100).toFixed(1)}% Fade` : "None";
  const slingshotStat = slingshotTicker !== "None" ? `+${(biggestRecovery * 100).toFixed(1)}% Swing` : "None";

  const conArtistLog = conArtistTicker !== "None" ? `${conArtistTicker} (${conArtistStat})` : "None";
  const slingshotLog = slingshotTicker !== "None" ? `${slingshotTicker} (${slingshotStat})` : "None";

  logSheet.appendRow([
    new Date().toLocaleDateString(), new Date().toLocaleTimeString(), totalDollarVol, 
    `${daddyData.ticker} (${daddyData.stat})`, `${craterData.ticker} (${craterData.stat})`, 
    `${heavyData.ticker} (${heavyData.stat})`, `${yeetData.ticker} (${yeetData.stat})`, 
    `${silenceData.ticker} (${silenceData.stat})`, conArtistLog, slingshotLog
  ]);

  awardSheet.clear(); 
  const dailyAwards = [
    [daddyData.ticker, "Space Daddy", `${daddyData.stat} Gain`],
    [craterData.ticker, "Crater Maker", `${craterData.stat} Loss`],
    [heavyData.ticker, "Super Heavy Lift", `${heavyData.stat} $ Vol`],
    [yeetData.ticker, "Orbital Yeet", `${yeetData.stat} RVol`],
    [silenceData.ticker, "Deep Space Silence", `${silenceData.stat} RVol`],
    [conArtistTicker, "Con Artist", conArtistStat],
    [slingshotTicker, "Slingshot Maneuverer", slingshotStat]
  ];

  awardSheet.getRange("A1:C1").setValues([["Ticker", "Award", "Stat"]]).setFontWeight("bold").setBackground("#1DA1F2").setFontColor("white");
  awardSheet.getRange(2, 1, dailyAwards.length, 3).setValues(dailyAwards).setHorizontalAlignment("left");

  const formattedDate = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MMM d, yyyy");
  let dailyTweet = `Space Grammys - ${formattedDate}\n\n`;
  let uniqueTickers = new Set();
  dailyAwards.forEach(row => {
    if(row[0] !== "None") {
      dailyTweet += `${row[1]}: $${row[0]} (${row[2]})\n`;
      uniqueTickers.add(`$${row[0]}`);
    }
  });
  dailyTweet += `\n${Array.from(uniqueTickers).join(" ")}`;

  awardSheet.getRange("E1").setValue("📋 DAILY TWEET").setFontWeight("bold").setFontColor("#1DA1F2");
  awardSheet.getRange("E2").setValue(dailyTweet).setVerticalAlignment("top").setWrap(true);

  awardSheet.autoResizeColumns(1, 10);
  
  return {
    tweet: dailyTweet,
    trendTweet: trendTweet,
    totalVol: totalDollarVol
  };
}

function sendMissionReportEmail(summaryData, results, headers) {
  const recipient = Session.getActiveUser().getEmail();
  const dateStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MMM. d");
  const subject = `🚀 Mission Report: Sector $ Vol $${(summaryData.totalVol / 1000000).toFixed(2)}M`;
  
  let tableHtml = `<table border="1" style="border-collapse: collapse; font-family: sans-serif; font-size: 11px;">
    <tr style="background-color: #2d2d2d; color: white;">
      <th>${headers.join('</th><th>')}</th>
    </tr>`;
  
  results.forEach(row => {
    tableHtml += '<tr>';
    row.forEach((cell, index) => {
      let formatted = cell;
      if (typeof cell === 'number') {
        if (index === 1 || index === 9 || index === 10 || index === 11) formatted = '$' + cell.toLocaleString();
        else if (index === 2 || index === 5 || index === 12 || index === 13) formatted = (cell * 100).toFixed(2) + '%';
        else formatted = cell.toLocaleString();
      }
      tableHtml += `<td style="padding: 4px; text-align: center;">${formatted}</td>`;
    });
    tableHtml += '</tr>';
  });
  tableHtml += '</table>';

  const body = `
    <h2>Mission Control Summary</h2>
    <div style="display: flex; gap: 20px;">
      <div style="flex: 1; background: #f4f4f4; padding: 10px; border-left: 5px solid #1DA1F2;">
        <h4>🏆 Space Grammys</h4>
        <pre style="white-space: pre-wrap; margin: 0; font-size: 12px;">${summaryData.tweet}</pre>
      </div>
      <div style="flex: 1; background: #e8f5e9; padding: 10px; border-left: 5px solid #4caf50;">
        <h4>📈 Sector Trend (5D)</h4>
        <pre style="white-space: pre-wrap; margin: 0; font-size: 12px;">${summaryData.trendTweet}</pre>
      </div>
    </div>
    <hr>
    <h3>Market Data - ${dateStr}</h3>
    ${tableHtml}
  `;

  MailApp.sendEmail({
    to: recipient,
    subject: subject,
    htmlBody: body
  });
}
